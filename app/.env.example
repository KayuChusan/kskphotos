# Database (ローカル開発用)
DATABASE_URL="postgresql://kskphotos:kskphotos_dev@localhost:5433/photo_portfolio"

# NextAuth.js
AUTH_SECRET="your-secret-here"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Cloud Storage (本番のみ)
GCS_BUCKET_NAME=""
GCS_PROJECT_ID=""

# メール通知 (Resend)
RESEND_API_KEY=""
NOTIFICATION_EMAIL=""                                # 運営の受信先 (例 contact@kskworks.jp)
NOTIFICATION_FROM="KSK Works <noreply@kskworks.jp>"  # 検証済みドメインの送信元

# アクセス解析 (Google Analytics 4)
# 本番ビルド時に設定すると有効化（NEXT_PUBLIC_* はビルド時にインライン化される）。
# ローカルでは未設定のままにする（コンポーネントが何も出力せず計測しない）。
NEXT_PUBLIC_GA_ID=""                                 # 例 G-XXXXXXXXXX

# 地図 (Mapbox or Google Maps)
NEXT_PUBLIC_MAPBOX_TOKEN=""
