generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// 認証（NextAuth.js v5 — 管理者のみ）
// ============================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(ADMIN)
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum UserRole {
  ADMIN
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ============================================
// 写真（EXIF 全フィールド + GPS + ビフォーアフター）
// ============================================

// ============================================
// コレクション（シリーズ単位の見せ方）
// ============================================

model Collection {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  isPublished Boolean  @default(true)
  // true の場合、会員解錠（UnlockToken）まで EXIF・現像メモ・マスク・高画素を出さない
  isLocked    Boolean  @default(false)
  sortOrder   Int      @default(0)
  photos      Photo[]
  unlockTokens UnlockToken[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 会員解錠トークン。note の限定記事に貼る /u/<token> リンクの実体。
// 平文は発行時に一度だけ表示し、DB にはハッシュのみ保存する。
model UnlockToken {
  id           String     @id @default(cuid())
  tokenHash    String     @unique
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  label        String?
  expiresAt    DateTime?
  revoked      Boolean    @default(false)
  createdAt    DateTime   @default(now())

  @@index([collectionId])
}

model Photo {
  id          String   @id @default(cuid())
  title       String
  description String?
  slug        String?  @unique

  // 所属コレクション（シリーズ）
  collectionId String?
  collection   Collection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)

  // 画像URL
  imageUrl    String
  beforeUrl   String?
  thumbnailUrl String?
  blurDataUrl String?
  // 高画素ダウンロード用（会員解錠時のみ配信。公開URLには出さない）
  originalUrl String?

  // カテゴリ・タグ
  category    PhotoCategory
  tags        String[]

  // 現像レシピ（Lightroom での調整内容）
  developNotes String?

  // 撮影場所
  location    String?
  latitude    Float?
  longitude   Float?

  // EXIF（アップロード時に exifr で自動抽出）
  cameraModel  String?
  lensMake     String?
  lensModel    String?
  focalLength  Float?
  aperture     Float?
  shutterSpeed String?
  iso          Int?
  dateTaken    DateTime?
  whiteBalance String?
  meteringMode String?
  imageWidth   Int?
  imageHeight  Int?

  // 表示制御
  isPortfolio Boolean @default(false)
  isPublished Boolean @default(true)
  // トップのヒーローセクション候補。指定された写真からランダムで1枚表示する
  isHero      Boolean @default(false)
  // （未使用・廃止予定）旧・個別マスクフラグ。マスクはコレクション単位に統一
  isLocked    Boolean @default(false)
  sortOrder   Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([isPortfolio])
  @@index([dateTaken])
}

enum PhotoCategory {
  PORTRAIT
  LANDSCAPE
  EVENT
  STREET
  ARCHITECTURE
  FOOD
  OTHER
}

// ============================================
// 撮影サービス（メニュー・料金）
// ============================================

model Service {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Int
  // 価格の補足表記（"〜" / "要相談" / "月額〜" など。price=0 のときは単体で表示）
  priceNote   String?
  duration    String?
  category    ServiceCategory
  imageUrl    String?
  features    String[]
  isActive    Boolean  @default(true)
  isPopular   Boolean  @default(false)
  sortOrder   Int      @default(0)
  bookings    Booking[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum ServiceCategory {
  PORTRAIT
  FAMILY
  EVENT
  COMMERCIAL
  LOCATION
  POLITICS
  WEB_PRODUCTION
  IT_SUPPORT
}

// ============================================
// 実績（案件ログ）
// ============================================

model CaseStudy {
  id           String        @id @default(cuid())
  date         DateTime // 実施日（表示・並び替えの基準）
  type         CaseStudyType
  title        String // 一文の説明（公開文。匿名化はこの文面で行う）
  detail       String? // 任意の補足
  thumbnailUrl String? // サムネ1枚（任意）
  linkUrl      String? // 任意リンク（制作サイト等）
  linkLabel    String? // リンクの表示名
  isPublished  Boolean       @default(true) // 公開可否（掲載許可の管理）
  sortOrder    Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

enum CaseStudyType {
  PHOTO
  WEB
  IT
}

// ============================================
// 撮影依頼
// ============================================

model Booking {
  id            String        @id @default(cuid())
  name          String
  email         String
  phone         String?
  serviceId     String?
  service       Service?      @relation(fields: [serviceId], references: [id])
  preferredDate DateTime?
  location      String?
  message       String
  status        BookingStatus @default(PENDING)
  adminNote     String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

// ============================================
// ブログ
// ============================================

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String
  excerpt     String?
  coverImage  String?
  categories  String[]
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished, publishedAt])
}

// ============================================
// お問い合わせ
// ============================================

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([isRead])
  @@index([createdAt])
}

// ============================================
// プロフィール（/about の編集可能コンテンツ・単一レコード）
// id は固定値 "singleton" で1行のみ運用する
// ============================================

model SiteProfile {
  id           String   @id @default("singleton")
  name         String   @default("")
  tagline      String   @default("")
  bio          String   @default("")
  // プロフィール写真（公開URL）と blur プレースホルダ
  profileImage String?
  profileBlur  String?
  // 撮影機材。各行 "名称 | 補足" 形式の文字列配列
  gearBody     String[]
  gearLenses   String[]
  gearSoftware String[]
  // 撮影ポリシー
  policyBadge  String   @default("")
  policy       String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
